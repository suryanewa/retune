{
  "$schema": "../node_modules/retune/manifest.schema.json",
  "components": {
    "Avatar": {
      "props": {
        "initials": {
          "type": "string",
          "description": "Two-letter text displayed inside the avatar circle"
        },
        "size": {
          "type": "enum",
          "values": ["sm", "md", "lg"],
          "default": "md",
          "description": "Avatar size variant",
          "class_map": {
            "sm": "avatar--sm",
            "md": "avatar--md",
            "lg": "avatar--lg"
          }
        }
      }
    },
    "Badge": {
      "props": {
        "variant": {
          "type": "enum",
          "values": ["success", "warning", "error", "info"],
          "description": "Badge color variant",
          "class_map": {
            "success": "badge-success",
            "warning": "badge-warning",
            "error": "badge-error",
            "info": "badge-info"
          }
        }
      }
    },
    "Tag": {
      "props": {
        "color": {
          "type": "enum",
          "values": ["blue", "green", "amber", "purple"],
          "description": "Tag color variant",
          "class_map": {
            "blue": "tag-blue",
            "green": "tag-green",
            "amber": "tag-amber",
            "purple": "tag-purple"
          }
        }
      }
    },
    "SettingsDrawer": {
      "props": {
        "open": {
          "type": "boolean",
          "default": false,
          "description": "Whether the drawer is visible"
        },
        "onClose": {
          "type": "function",
          "description": "Callback fired when the drawer requests to close"
        }
      }
    },
    "MailApp": {
      "props": {},
      "state": {
        "activeFolder": {
          "type": "enum",
          "values": ["Inbox", "Drafts", "Starred", "Sent", "Archive", "Trash"],
          "default": "Inbox",
          "description": "Currently selected sidebar folder"
        },
        "selectedMessage": {
          "type": "number",
          "default": 1,
          "description": "ID of the selected message, or null"
        },
        "composeOpen": {
          "type": "boolean",
          "default": false,
          "description": "Whether the compose modal is open"
        },
        "searchFocused": {
          "type": "boolean",
          "default": false,
          "description": "Whether the search input has focus"
        },
        "settingsOpen": {
          "type": "boolean",
          "default": false,
          "description": "Whether the settings drawer is open"
        }
      }
    }
  },
  "tokens": {
    "spacing": {
      "spacing-1": { "value": "4px", "variable": "--spacing-1" },
      "spacing-2": { "value": "8px", "variable": "--spacing-2" },
      "spacing-3": { "value": "12px", "variable": "--spacing-3" },
      "spacing-4": { "value": "16px", "variable": "--spacing-4" },
      "spacing-6": { "value": "24px", "variable": "--spacing-6" },
      "spacing-8": { "value": "32px", "variable": "--spacing-8" },
      "spacing-12": { "value": "48px", "variable": "--spacing-12" }
    },
    "sizes": {
      "size-sm": { "value": "24px", "variable": "--size-sm" },
      "size-md": { "value": "32px", "variable": "--size-md" },
      "size-lg": { "value": "48px", "variable": "--size-lg" },
      "size-xl": { "value": "64px", "variable": "--size-xl" }
    },
    "colors": {
      "color-brand": { "value": "#2563eb", "variable": "--color-brand" },
      "color-brand-light": { "value": "#60a5fa", "variable": "--color-brand-light" },
      "color-brand-dark": { "value": "#1d4ed8", "variable": "--color-brand-dark" },
      "color-accent": { "value": "#8b5cf6", "variable": "--color-accent" },
      "color-text": { "value": "#1c1917", "variable": "--color-text" },
      "color-text-muted": { "value": "#78716c", "variable": "--color-text-muted" },
      "color-text-subtle": { "value": "#a8a29e", "variable": "--color-text-subtle" },
      "color-bg": { "value": "#ffffff", "variable": "--color-bg" },
      "color-bg-subtle": { "value": "#fafaf9", "variable": "--color-bg-subtle" },
      "color-bg-muted": { "value": "#f5f5f4", "variable": "--color-bg-muted" },
      "color-bg-hover": { "value": "#e7e5e4", "variable": "--color-bg-hover" },
      "color-border": { "value": "#e7e5e4", "variable": "--color-border" },
      "color-border-strong": { "value": "#d6d3d1", "variable": "--color-border-strong" },
      "color-success": { "value": "#16a34a", "variable": "--color-success" },
      "color-danger": { "value": "#dc2626", "variable": "--color-danger" },
      "color-warning": { "value": "#d97706", "variable": "--color-warning" }
    },
    "radii": {
      "radius-sm": { "value": "4px", "variable": "--radius-sm" },
      "radius-md": { "value": "8px", "variable": "--radius-md" },
      "radius-lg": { "value": "12px", "variable": "--radius-lg" },
      "radius-xl": { "value": "16px", "variable": "--radius-xl" },
      "radius-full": { "value": "9999px", "variable": "--radius-full" }
    },
    "borderWidths": {
      "border-width-thin": { "value": "1px", "variable": "--border-width-thin" },
      "border-width-medium": { "value": "2px", "variable": "--border-width-medium" },
      "border-width-thick": { "value": "4px", "variable": "--border-width-thick" }
    },
    "shadows": {
      "shadow-sm": { "value": "0 1px 2px rgba(0,0,0,0.05)", "variable": "--shadow-sm" },
      "shadow-md": { "value": "0 4px 6px -1px rgba(0,0,0,0.1)", "variable": "--shadow-md" },
      "shadow-lg": { "value": "0 10px 15px -3px rgba(0,0,0,0.1)", "variable": "--shadow-lg" }
    },
    "typography": {
      "font-xs": { "value": "11px", "variable": "--font-xs" },
      "font-sm": { "value": "13px", "variable": "--font-sm" },
      "font-base": { "value": "14px", "variable": "--font-base" },
      "font-lg": { "value": "16px", "variable": "--font-lg" },
      "font-xl": { "value": "20px", "variable": "--font-xl" },
      "font-2xl": { "value": "24px", "variable": "--font-2xl" },
      "font-weight-normal": { "value": "400", "variable": "--font-weight-normal" },
      "font-weight-medium": { "value": "500", "variable": "--font-weight-medium" },
      "font-weight-semibold": { "value": "600", "variable": "--font-weight-semibold" },
      "font-weight-bold": { "value": "700", "variable": "--font-weight-bold" },
      "leading-tight": { "value": "1.25", "variable": "--leading-tight" },
      "leading-normal": { "value": "1.5", "variable": "--leading-normal" },
      "leading-relaxed": { "value": "1.75", "variable": "--leading-relaxed" },
      "tracking-tight": { "value": "-0.025em", "variable": "--tracking-tight" },
      "tracking-normal": { "value": "0em", "variable": "--tracking-normal" },
      "tracking-wide": { "value": "0.05em", "variable": "--tracking-wide" }
    }
  }
}
