{
  "name": "retune",
  "private": true,
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run build -w retune && npm run dev -w retune & npm run dev -w playground",
    "dev:overlay": "npm run dev -w retune",
    "dev:playground": "npm run dev -w playground",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "retune": "^0.3.0"
  },
  "devDependencies": {
    "vitest": "^4.0.18"
  }
}
